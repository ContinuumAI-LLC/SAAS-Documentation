{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Continuum AI",
  "colors": {
    "primary": "#FF5A1F",
    "light": "#FF7A45",
    "dark": "#FF5A1F"
  },
  "favicon": "/favicon.png",
  "api": {
    "mdx": {
      "server": "https://api.continuumai.technology",
      "auth": {
        "method": "bearer"
      }
    },
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["bash", "python", "javascript", "go"],
      "defaults": "required"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "api-reference/models",
              "api-reference/errors"
            ]
          },
          {
            "group": "Text generation",
            "pages": [
              "api-reference/responses",
              "api-reference/chat-completions"
            ]
          },
          {
            "group": "Embeddings & search",
            "pages": [
              "api-reference/embeddings",
              "api-reference/vector-stores"
            ]
          },
          {
            "group": "Media",
            "pages": [
              "api-reference/images",
              "api-reference/audio"
            ]
          },
          {
            "group": "Conversations",
            "pages": [
              "api-reference/threads"
            ]
          },
          {
            "group": "Data & training",
            "pages": [
              "api-reference/files",
              "api-reference/fine-tuning",
              "api-reference/batches"
            ]
          },
          {
            "group": "Safety & usage",
            "pages": [
              "api-reference/moderations",
              "api-reference/usage-billing"
            ]
          }
        ]
      },
      {
        "tab": "API en Español",
        "groups": [
          {
            "group": "Descripción general",
            "pages": [
              "es/introduccion",
              "es/autenticacion",
              "es/modelos",
              "es/errores"
            ]
          },
          {
            "group": "Generación de texto",
            "pages": [
              "es/responses",
              "es/chat-completions"
            ]
          },
          {
            "group": "Embeddings y búsqueda",
            "pages": [
              "es/embeddings",
              "es/vector-stores"
            ]
          },
          {
            "group": "Media",
            "pages": [
              "es/imagenes",
              "es/audio"
            ]
          },
          {
            "group": "Conversaciones",
            "pages": [
              "es/threads"
            ]
          },
          {
            "group": "Datos y entrenamiento",
            "pages": [
              "es/archivos",
              "es/fine-tuning",
              "es/lotes"
            ]
          },
          {
            "group": "Seguridad y uso",
            "pages": [
              "es/moderaciones",
              "es/uso-facturacion"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "href": "/api-reference/introduction",
          "icon": "code"
        },
        {
          "anchor": "Changelog",
          "href": "/changelog",
          "icon": "clock-rotate-left"
        },
        {
          "anchor": "Status",
          "href": "https://status.continuumai.app",
          "icon": "signal"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo-light.png",
    "dark": "/logo/logo-dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@continuum-ai.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.continuum-ai.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/continuum_ai",
      "github": "https://github.com/continuum-ai",
      "linkedin": "https://linkedin.com/company/continuum-ai"
    }
  }
}
